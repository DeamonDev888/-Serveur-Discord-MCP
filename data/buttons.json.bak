  {
    "id": "btn_change_theme",
    "messageId": "unknown",
    "channelId": "unknown",
    "label": "changer_theme",
    "action": {
      "type": "custom",
      "data": {}
    },
    "functionCode": "// Fonction pour changer le thème de l'embed\nconst themes = ['cyberpunk', 'minimal', 'gaming', 'corporate', 'sunset', 'ocean'];\nconst couleurs = ['#ff00ff', '#00ffff', '#ffff00', '#ff8800', '#ff4444', '#44ff44'];\n\nlet index = 0;\n\n// Modifier l'embed avec un nouveau thème\nmodifyEmbed({\n  theme: themes[index % themes.length],\n  color: couleurs[index % couleurs.length]\n});\n\nindex++;\n\nreturn `🎨 Thème appliqué : **${themes[(index-1) % themes.length]}** !`;",
    "createdAt": "2025-12-26T02:59:38.021Z"
  },
  {
    "id": "btn_stats",
    "messageId": "unknown",
    "channelId": "unknown",
    "label": "afficher_stats",
    "action": {
      "type": "custom",
      "data": {}
    },
    "functionCode": "// Fonction pour afficher les statistiques\nconst stats = {\n  'Embeds créés': Math.floor(Math.random() * 1000),\n  'Boutons activés': Math.floor(Math.random() * 500),\n  'Actions personnalisées': Math.floor(Math.random() * 200),\n  'Utilisateurs actifs': Math.floor(Math.random() * 50)\n};\n\n// Récupérer la valeur saisie dans le modal\nconst inputValue = ctx.modalValues?.input || 'général';\n\nlet message = `📊 **Statistiques (${inputValue})**\\n\\n`;\n\nfor (const [key, value] of Object.entries(stats)) {\n  message += `• **${key}** : ${value}\\n`;\n}\n\nmessage += `\\n⏰ Mis à jour : <t:${Math.floor(Date.now()/1000)}:R>`;\n\nawait ctx.sendMessage(message);",
    "createdAt": "2025-12-26T02:59:43.951Z"
  },
  {
    "id": "noel_2025_souhait",
    "messageId": "1454133248824315936",
    "channelId": "1442317829998383235",
    "label": "🎊 Souhaiter une bonne année",
    "action": {
