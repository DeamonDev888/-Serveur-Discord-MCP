[
  {
    "id": "sentinel_vote_valid_public",
    "messageId": "1463527338645131469",
    "channelId": "1460428956518846466",
    "label": "✅ CONFIRMER",
    "action": {
      "type": "custom",
      "data": {
        "message": "Action ✅ CONFIRMER effectuée ✅"
      }
    },
    "createdAt": "2026-01-19T03:03:32.736Z",
    "functionCode": "\n            await ctx.saveVote('VALID');\n            const embed = ctx.interaction.message.embeds[0];\n            let fields = [...(embed.fields || [])].filter(f => !f.name.includes('COMMUNAUTÉ') && !f.name.includes('CONSENSUS'));\n            let voters = [];\n            const oldField = embed.fields?.find(f => f.name.includes('COMMUNAUTÉ'));\n            if (oldField) voters = oldField.value.split('\\n');\n            const userTag = '**' + ctx.interaction.user.username + '**';\n            voters = voters.filter(v => !v.includes(userTag));\n            voters.push('🟢' + ' ' + userTag);\n            const vAcc = voters.filter(v => v.includes('🟢')).length;\n            const total = voters.length;\n            const p = Math.round((vAcc / (total||1)) * 100);\n            const bar = '█'.repeat(Math.round(p/10)) + '░'.repeat(10 - Math.round(p/10));\n            const vRef = total - vAcc;\n            fields.push(\n                { name: '👥 COMMUNAUTÉ', value: voters.join('\\n'), inline: true },\n                { name: '📊 CONSENSUS', value: '`' + bar + '` **' + p + '%**\\n🟢 ' + vAcc + ' Bull | 🔴 ' + vRef + ' Bear', inline: true }\n            );\n            await ctx.update({ embeds: [{ ...embed.toJSON(), fields }] });\n            await ctx.followUp('✅ **VOTE ENREGISTRÉ**', true);\n        "
  },
  {
    "id": "sentinel_vote_invalid_public",
    "messageId": "1463527338645131469",
    "channelId": "1460428956518846466",
    "label": "⚠️ CONTESTER",
    "action": {
      "type": "custom",
      "data": {
        "message": "Action ⚠️ CONTESTER effectuée ✅"
      }
    },
    "createdAt": "2026-01-19T03:03:32.738Z",
    "functionCode": "\n            await ctx.saveVote('INVALID');\n            const embed = ctx.interaction.message.embeds[0];\n            let fields = [...(embed.fields || [])].filter(f => !f.name.includes('COMMUNAUTÉ') && !f.name.includes('CONSENSUS'));\n            let voters = [];\n            const oldField = embed.fields?.find(f => f.name.includes('COMMUNAUTÉ'));\n            if (oldField) voters = oldField.value.split('\\n');\n            const userTag = '**' + ctx.interaction.user.username + '**';\n            voters = voters.filter(v => !v.includes(userTag));\n            voters.push('🔴' + ' ' + userTag);\n            const vAcc = voters.filter(v => v.includes('🟢')).length;\n            const total = voters.length;\n            const p = Math.round((vAcc / (total||1)) * 100);\n            const bar = '█'.repeat(Math.round(p/10)) + '░'.repeat(10 - Math.round(p/10));\n            const vRef = total - vAcc;\n            fields.push(\n                { name: '👥 COMMUNAUTÉ', value: voters.join('\\n'), inline: true },\n                { name: '📊 CONSENSUS', value: '`' + bar + '` **' + p + '%**\\n🟢 ' + vAcc + ' Bull | 🔴 ' + vRef + ' Bear', inline: true }\n            );\n            await ctx.update({ embeds: [{ ...embed.toJSON(), fields }] });\n            await ctx.followUp('✅ **VOTE ENREGISTRÉ**', true);\n        "
  },
