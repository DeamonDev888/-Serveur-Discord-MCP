{
  "name": "discord-mcp-server",
  "version": "2.1.3",
  "description": "A comprehensive MCP server for Discord interaction with powerful tools and features",
  "main": "dist/index.js",
  "type": "module",
  "author": "Deamon",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start:bridge": "node scripts/start.js",
    "check": "node -e \"import('./src/config.js').then(m=>console.log('Configuration OK')).catch(e=>{console.error('Configuration:',e.message);process.exit(1)})\"",
    "clean": "node -e \"import fs from 'node:fs'; if(fs.existsSync('dist')) fs.rmSync('dist',{recursive:true}); const files=fs.readdirSync('.').filter(f=>f.endsWith('.log')); files.forEach(f=>fs.unlinkSync(f)); console.log('Cleaned')\"",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prebuild": "npm run clean",
    "postbuild": "echo Build completed successfully",
    "mcp:test": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "discord",
    "discord.js",
    "fastmcp",
    "typescript",
    "bot",
    "chat",
    "automation",
    "model-context-protocol"
  ],
  "dependencies": {
    "discord.js": "^14.17.3",
    "dotenv": "^16.3.1",
    "fastmcp": "^3.29.0",
    "sharp": "^0.34.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
